# Leave unset to run against the built-in local adapter (seeded, zero setup).
# Set both to point the app at a Supabase project instead — e.g. the values
# printed by `supabase start` after applying supabase/migrations + seed.sql.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Shared secret the client echoes to /api/groom in the x-groom-secret header.
# Set it to the same value as the server's GROOM_SECRET env var. This is a
# cost gate to keep casual traffic off the paid grooming endpoint, NOT a
# security boundary: any VITE_ value is baked into the browser bundle at build
# time and is readable by anyone. In dev the grooming call never leaves the
# browser (it drafts locally), so this only matters for deployed builds.
VITE_GROOM_SECRET=
